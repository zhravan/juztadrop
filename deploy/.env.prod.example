# Copy to .env in project root (or set in your deployment environment).
# Required for: docker-compose -f docker-compose.prod.yml up -d

# Image registry (e.g. GHCR). No trailing slash.
REGISTRY=ghcr.io/juztadrop/juztadrop
IMAGE_TAG=latest

# Database (required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=justadrop

# Optional: skip API migrations on startup (run them separately)
# RUN_MIGRATIONS=false

# Optional: CORS origins (comma-separated). Defaults match juztadrop.com.
# CORS_ORIGIN=https://juztadrop.com,https://www.juztadrop.com,https://dashboard.juztadrop.com

# Public API URL used by view and dashboard (default: https://api.juztadrop.com)
# NEXT_PUBLIC_API_URL=https://api.juztadrop.com

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@juztadrop.com
RESEND_FROM_NAME=JuztADrop
